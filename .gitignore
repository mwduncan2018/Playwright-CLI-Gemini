# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ------------------------------------------------------------------------------
# Environment & Secrets (CRITICAL)
# ------------------------------------------------------------------------------
.env
*.env
.env.*
!.env.example
auth.json             # Playwright storage state/session data
storageState.json     # Common alternative name for auth state
.playwright/.auth/    # Internal Playwright auth folder

# ------------------------------------------------------------------------------
# AI Agent & Playwright CLI Context
# ------------------------------------------------------------------------------
.playwright-cli/      # Temporary browser snapshots
.claude/              # Claude Code sessions, cache, and internal data
.gemini/              # Gemini CLI specific local configurations/cache
CLAUDE.local.md       # Local agent overrides
GEMINI.local.md       # Personal Gemini instruction overrides
.aiignore             # Standardized AI exclusion file

# ------------------------------------------------------------------------------
# Playwright Execution & Reports
# ------------------------------------------------------------------------------
test-results/
playwright-report/
blob-report/
allure-results/       # If using Allure reporting
playwright/.cache/
.local-browsers/      # Locally installed browser binaries
*.trace.zip           # Individual test traces

# ------------------------------------------------------------------------------
# Media & Visuals (Refined)
# ------------------------------------------------------------------------------
# Ignore accidental screenshots/videos in root, but allow test snapshots
screenshot.png
*.webm
*.zip
# If you DO NOT use visual regression testing, keep these:
# *.png
# *.jpg

# ------------------------------------------------------------------------------
# Personal & Local Scratch Files
# ------------------------------------------------------------------------------
__NOTES__.txt         # Your personal scratch file seen in repo
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp